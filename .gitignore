# Python caches
__pycache__/
*.py[cod]
*.so
.Python

# Virtual environments
.venv/
venv/
env/

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# IDE / system
.idea/
.vscode/
.DS_Store
Thumbs.db

# Logs / tracking
*.log
logs/
wandb/
mlruns/

# Notebook artifacts
.ipynb_checkpoints/

# Generic experiment artifacts
**/output/
**/results/
**/checkpoints/
**/ckpt/
**/ckpts/
**/runs/
**/exp/

# Managed outputs (keep folder skeleton only)
outputs/figures/*
outputs/tables/*
outputs/cached_results/*
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/cached_results/.gitkeep

# Full-path / aggregation artifacts (large; never commit)
outputs/fullpath_training/
outputs/phase0_status/
outputs/promptad_pairwise/
outputs/**/raw_scores/

# Generated CSV/JSON under outputs (pairwise tables, unified raw, status logs)
outputs/**/*.csv
outputs/**/*.csv.gz
outputs/**/*.json
!outputs/**/.gitkeep

# PaDiM Protocol B per-seed job dirs when PADIM_OUTPUT_ROOT points under outputs/
outputs/padim_protocol_b_jobs/
outputs/padim_protocol_b_smallgrid/
outputs/padim_protocol_b_mvtec15x5/

# PromptAD minimal full-path smoke / train root (large; do not commit)
outputs/promptad_fullpath_minimal/
outputs/promptad_fullpath_bottle_k1_5seeds/
outputs/promptad_fullpath_mvtec_3cls_3shots_3seeds/
outputs/promptad_fullpath_27cls_3shots_5seeds/
outputs/promptad_fullpath_status/

